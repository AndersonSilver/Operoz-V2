{
  "name": "@operoz/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vitest run",
    "test:watch": "vitest",
    "migration:run": "tsx src/scripts/migrate.ts run",
    "migration:revert": "tsx src/scripts/migrate.ts revert"
  },
  "dependencies": {
    "argon2": "0.41.1",
    "connect-redis": "7.1.1",
    "cookie-parser": "1.4.7",
    "cors": "2.8.5",
    "dotenv": "16.4.7",
    "express": "4.21.2",
    "express-session": "1.18.1",
    "helmet": "8.0.0",
    "ioredis": "5.4.2",
    "nodemailer": "6.9.16",
    "pg": "8.13.1",
    "pino": "9.6.0",
    "pino-http": "10.4.0",
    "rate-limiter-flexible": "5.0.5",
    "reflect-metadata": "0.2.2",
    "typeorm": "0.3.20",
    "zod": "3.24.1"
  },
  "devDependencies": {
    "@types/cookie-parser": "1.4.8",
    "@types/cors": "2.8.17",
    "@types/express": "4.17.21",
    "@types/express-session": "1.18.1",
    "@types/node": "22.10.5",
    "@types/nodemailer": "6.4.17",
    "@types/supertest": "6.0.2",
    "pino-pretty": "13.0.0",
    "supertest": "7.0.0",
    "tsx": "4.19.2",
    "typescript": "5.7.3",
    "vitest": "2.1.8"
  }
}
