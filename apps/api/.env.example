# Ambiente
NODE_ENV=development
PORT=3000

# Banco de dados
DATABASE_URL=postgres://operoz:operoz@localhost:5432/operoz

# Redis (sessão, rate limiting, cache)
REDIS_URL=redis://localhost:6379

# Sessão
SESSION_SECRET=troque-por-um-segredo-forte-em-producao
SESSION_COOKIE_NAME=operoz_session
SESSION_COOKIE_MAX_AGE_MS=604800000
COOKIE_DOMAIN=

# CORS — origens permitidas (separadas por vírgula)
CORS_ALLOWED_ORIGINS=http://localhost:3001,http://localhost:3002

# E-mail (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="Operoz <no-reply@operoz.local>"

# URLs base (usadas em links de e-mail: magic link, reset de senha, convites)
WEB_URL=http://localhost:3001

# OAuth — Google
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/auth/oauth/google/callback

# OAuth — GitHub
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_REDIRECT_URI=http://localhost:3000/auth/oauth/github/callback

# OAuth — GitLab
GITLAB_OAUTH_CLIENT_ID=
GITLAB_OAUTH_CLIENT_SECRET=
GITLAB_OAUTH_REDIRECT_URI=http://localhost:3000/auth/oauth/gitlab/callback

# OAuth — Gitea
GITEA_OAUTH_CLIENT_ID=
GITEA_OAUTH_CLIENT_SECRET=
GITEA_OAUTH_REDIRECT_URI=http://localhost:3000/auth/oauth/gitea/callback
GITEA_BASE_URL=
